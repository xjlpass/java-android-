<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- 发送通知权限 -->
    <!-- android 13引入的 “通知运行时权限” -->
    <!--
    普通通知	✅
            前台 Service 通知	✅
            常驻通知	✅
            后台任务通知	✅
    -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" /> <!-- 访问网络缺陷 -->
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.AndroidLearn"
        tools:targetApi="31">
        <service
            android:name=".fragment.MyIntentService"
            android:exported="false"></service>

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.AndroidLearn">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".handler.HandlerActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.AndroidLearn" />
        <activity
            android:name=".handler.HandlerActivityB"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.AndroidLearn" />
        <activity
            android:name=".animation.FrameAnimationActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.AndroidLearn" />
        <activity
            android:name=".animation.PropertyAnimationActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.AndroidLearn" />
        <activity
            android:name=".animation.TweenedAnimationActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.AndroidLearn" />
        <activity
            android:name=".layoutparams.LayoutParamsActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.AndroidLearn" />
        <activity
            android:name=".channel.ChannelActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.AndroidLearn" />
        <activity
            android:name=".surface.SurfaceActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.AndroidLearn" />
        <activity
            android:name=".menu.MenuActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.AndroidLearn"
            tools:ignore="MissingClass" />
        <activity
            android:name=".decorator.DecoratorActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.AndroidLearn"
            tools:ignore="MissingClass" />
        <activity
            android:name=".interceptor.InterceptorActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.AndroidLearn"
            tools:ignore="MissingClass" />
        <activity
            android:name=".okhttp.OkHttpActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.AndroidLearn"
            tools:ignore="MissingClass" />
        <activity
            android:name=".handlethread.FileWriteActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.AndroidLearn"
            tools:ignore="MissingClass" />
        <activity
            android:name=".binder.BinderActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.AndroidLearn"
            tools:ignore="MissingClass" /> <!-- Scheme 目标Activity 配置 -->
        <activity
            android:name=".scheme.SchemeActivity"
            android:exported="true"
            android:launchMode="singleTask"> <!-- 必须singleTask 触发onNewIntent -->

            <intent-filter>
                <action android:name="android.intent.action.VIEW" />

                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />

                <!-- 自定义Scheme规则：myapp://jump/detail -->
                <data
                    android:host="jump"
                    android:path="/detail"
                    android:scheme="myapp" />
            </intent-filter>
        </activity>

        <service
            android:name=".DemoService"
            android:exported="false"
            android:foregroundServiceType="dataSync" /> <!-- 模拟远程进程与主线程通过 binder 的通信 -->
        <service
            android:name=".binder.ACService"
            android:exported="true"
            android:process=":remote" /> <!-- android:process=":remote"   只有同一个应用可以访问该进程 -->
        <!-- 不带冒号（如 remote）：表示全局进程 -->
        <service
            android:name=".surface.SurfaceService"
            android:exported="true"
            android:process=":remote">
            <intent-filter>
                <action android:name="com.example.surface.SURFACE_SERVICE" />
            </intent-filter>
        </service>
    </application>

</manifest>